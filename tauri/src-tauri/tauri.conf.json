{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JvedioNext",
  "version": "0.1.0",
  "identifier": "com.jvedio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../build/frontend-stage"
  },
  "app": {
    "windows": [
      {
        "title": "Jvedio Next",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "resources": {
      "../../build/worker-stage/**/*": "worker/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
